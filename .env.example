# Control Network — environment configuration
# Copy this file to .env and fill in what you need. All vars are optional; the app
# runs fully in deterministic (no-AI) simulation mode with zero configuration.

# --- Anthropic (default LLM provider) ---
# CN_ANTHROPIC_API_KEY=sk-ant-...
# CN_LLM_MODEL=claude-haiku-4-5-20251001
# CN_LLM_MAX_TOKENS=500
# CN_LLM_TEMPERATURE=0.2

# --- Provider selection: anthropic | openai_compatible | ollama ---
# CN_LLM_PROVIDER=anthropic

# --- OpenAI-compatible endpoint (vLLM, LiteLLM, OpenAI itself, self-hosted proxies, etc.) ---
# Only used when CN_LLM_PROVIDER=openai_compatible
# CN_OPENAI_BASE_URL=https://api.openai.com/v1
# CN_OPENAI_API_KEY=sk-...
# CN_OPENAI_MODEL=gpt-4o-mini

# --- Local Ollama ---
# Only used when CN_LLM_PROVIDER=ollama
# CN_OLLAMA_BASE_URL=http://localhost:11434
# CN_OLLAMA_MODEL=llama3.1

# --- Slack Incoming Webhook (optional; POST /api/slack falls back to copy-to-clipboard if unset) ---
# CN_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- Data source: sim (demo scenarios, zero config) | prometheus | datadog ---
# CN_DATA_MODE=sim

# --- Prometheus / Alertmanager (live alerts IN + metric evidence) ---
# CN_PROMETHEUS_URL=http://localhost:9093
# CN_PROMETHEUS_TOKEN=
# CN_PROMETHEUS_TIMEOUT=3.0

# --- Datadog (triggered monitors + metrics/logs evidence; needs BOTH keys) ---
# CN_DATADOG_API_KEY=
# CN_DATADOG_APP_KEY=
# CN_DATADOG_SITE=datadoghq.com
# CN_DATADOG_TIMEOUT=3.0

# --- Kubernetes (pod describe/events/logs/deployment/node/pvc evidence; read-only) ---
# Set a kubeconfig path, or leave unset — in-cluster service account is auto-detected.
# CN_KUBECONFIG=~/.kube/config
# CN_K8S_TIMEOUT=5.0

# --- GitHub (recent merged PRs as "what changed" evidence; needs BOTH vars) ---
# CN_GITHUB_TOKEN=
# CN_GITHUB_REPO=owner/repo
# CN_GITHUB_TIMEOUT=5.0

# --- API token (optional; protects write endpoints when set) ---
# CN_API_TOKEN=change-me-to-a-strong-random-token

# --- Token budgeting for compressed context sent to the model ---
# CN_TOKEN_TARGET=800
# CN_TOKEN_HARD_CAP=2000

# --- Branding / display ---
# CN_CUSTOMER_NAME=DemoCorp

# --- Zero-retention mode (in-RAM only; should stay true) ---
# CN_ZDR_MODE=true

# --- Server bind address/port ---
# Loopback-only by default (safe). Set CN_HOST=0.0.0.0 ONLY if you deliberately want
# other machines on your network to reach the app.
# CN_HOST=127.0.0.1
# CN_PORT=8000
